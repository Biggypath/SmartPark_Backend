# ── Server ───────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Database (PostgreSQL) ────────────────────────────────
# When using docker-compose the hostname is the service name "postgres"
DATABASE_URL=postgresql://smartpark:smartpark_secret@postgres:5432/smartpark

# ── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_URL=amqp://smartpark:smartpark_secret@rabbitmq:5672

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── CORS ─────────────────────────────────────────────────
# Set to your frontend's URL in production.
# Accepts a comma-separated list for multiple origins.
# Use * to allow all origins (development only).
# Examples:
#   CORS_ORIGIN=https://smartpark.example.com
#   CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=*

# ── Docker Compose helpers (used in docker-compose.yml) ──
POSTGRES_PASSWORD=smartpark_secret
RABBITMQ_USER=smartpark
RABBITMQ_PASS=smartpark_secret
