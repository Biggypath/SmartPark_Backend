// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// Enums
// ---------------------------------------------------------

enum SlotStatus {
  FREE
  OCCUPIED
  ASSIGNED // Slot reserved by the system while the car drives to it
}

enum LogEventType {
  ENTRY
  EXIT
  OBSTRUCTION
}

enum PaymentStatus {
  PENDING
  PAID
}

enum UserRole {
  USER
  ADMIN
}

enum CardNetwork {
  VISA
  MASTERCARD
  JCB
  AMEX
  UNIONPAY
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ---------------------------------------------------------
// Identity & Privilege Models
// ---------------------------------------------------------

model User {
  user_id       String   @id @default(uuid())
  email         String   @unique // Used as the login username
  password_hash String   // Stores the encrypted password (e.g., via bcrypt)
  name          String
  role          UserRole @default(USER)
  birthday      DateTime? @db.Date
  gender        Gender?
  created_at    DateTime @default(now())

  // Relations: A user can hold multiple different cards
  cards UserCard[]

  @@map("users")
}

model PrivilegeProgram {
  program_id    String   @id @default(uuid())
  provider_name String   // e.g., "SCB First", "The 1 Card"
  tier          String?  // e.g., "Private Banking", "Gold"
  
  // An array of BINs (first 6-8 digits) that qualify for this program
  eligible_bins String[] 
  
  max_vehicles  Int      @default(1) // Enforces the card's policy on vehicle limits
  is_active     Boolean  @default(true)

  // Relations: The specific cards issued under this program
  issued_cards  UserCard[]

  @@map("privilege_programs")
}

model UserCard {
  card_id         String      @id @default(uuid())
  user_id         String
  program_id      String
  
  // Card Identity details (Safe to store)
  cardholder_name String?     // e.g., "SOMCHAI JAIDEE"
  label           String?     // e.g., "Personal Card", "Work Card"
  network         CardNetwork 
  bin             String      // First 6-8 digits (Used to match with PrivilegeProgram)
  last_four       String      // Last 4 digits (e.g., "1234") - safe to display on frontend
  expiry_month    Int         // e.g., 12
  expiry_year     Int         // e.g., 2028

  issued_at       DateTime    @default(now())
  is_active       Boolean     @default(true)

  // Relations
  user            User              @relation(fields: [user_id], references: [user_id])
  program         PrivilegeProgram  @relation(fields: [program_id], references: [program_id])
  
  // Many-to-Many: A single card can cover multiple vehicles (up to max_vehicles)
  vehicles        RegisteredVehicle[]

  // Ensure a user can't add the exact same card twice
  @@unique([user_id, bin, last_four])
  @@map("user_cards")
}

model RegisteredVehicle {
  vehicle_id    String   @id @default(uuid())
  registration  String   // e.g., "1กข 1234"
  province      String   // e.g., "กรุงเทพมหานคร"
  brand        String?  // e.g., "Toyota"
  model        String?  // e.g., "Camry"
  color        String?  // e.g., "Black"
  registered_at DateTime @default(now())

  // Many-to-Many: A single vehicle can be registered under multiple different cards
  cards UserCard[]

  // Relations: All parking sessions associated with this registered vehicle
  sessions ParkingSession[]

  // Ensures the combination of number + province is completely unique
  @@unique([registration, province])
  @@map("registered_vehicles")
}

// ---------------------------------------------------------
// Core Parking Models
// ---------------------------------------------------------

model PrivilegeParking {
  lot_id   String @id @default(uuid())
  name     String @unique // e.g., "CentralWorld The 1 Card", "CentralWorld SCB First"
  location String? // e.g., "123 Siam St, Pathum Wan, Bangkok"

  slots ParkingSlot[]
  pricingRule PricingRule?

  @@map("parking_lots")
}

model ParkingSlot {
  slot_id              String     @id // e.g. "A1", "B2"
  lot_id               String
  status               SlotStatus @default(FREE)
  location_coordinates String     // Stores JSON string "{x:10, y:0, z:5}" for Three.js
  is_active            Boolean    @default(true) // Hardware availability

  // Relations
  lot      PrivilegeParking       @relation(fields: [lot_id], references: [lot_id])
  logs     SensorLog[]
  sessions ParkingSession[]

  @@map("parking_slots")
}

model PricingRule {
  rule_id        String   @id @default(uuid())
  parkinglot_id  String   @unique
  rate_per_hour  Float    @default(20.00)
  effective_from DateTime @default(now())
  parkinglot           PrivilegeParking @relation(fields: [parkinglot_id], references: [lot_id])
  @@map("pricing_rules")
}

model SensorLog {
  log_id     String       @id @default(uuid())
  slot_id    String
  timestamp  DateTime     @default(now())
  event_type LogEventType
  raw_data   String?      // Raw IR sensor value from the ESP32

  // Relations
  slot ParkingSlot @relation(fields: [slot_id], references: [slot_id])

  @@map("sensor_logs")
}

model ParkingSession {
  session_id String  @id @default(uuid())
  slot_id    String? // Null for guest/unregistered vehicles (no slot assigned)

  // What the camera actually saw (works for both guests and registered)
  registration String?
  province     String?

  // Optional link to a registered vehicle. If null, this is a guest session.
  vehicle_id String?
  vehicle    RegisteredVehicle? @relation(fields: [vehicle_id], references: [vehicle_id])

  entry_time       DateTime      @default(now())
  exit_time        DateTime?
  duration_minutes Float?
  total_fee        Decimal?      @db.Decimal(10, 2)
  payment_status   PaymentStatus @default(PENDING)

  // Relations
  slot ParkingSlot? @relation(fields: [slot_id], references: [slot_id])

  @@map("parking_sessions")
}